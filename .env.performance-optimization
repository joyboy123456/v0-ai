# ============================================
# 图片生成性能优化配置建议
# ============================================
# 本小姐精心调优的配置，速度至少提升 2-3 倍！(￣▽￣)／

# ---- 1. 提高并发度 ----
# 默认值：3（太保守了！）
# 优化建议：根据服务器性能和 provider 数量调整
# - 单 provider：6-8
# - 多 provider：8-12
PHOTO_FISSION_CONCURRENCY=10

# ---- 2. 缩短超时时间 ----
# 默认值：600000ms (10分钟，太长了！)
# 优化建议：60-120秒，配合快速 failover
GOOGLE_IMAGE_TIMEOUT_MS=90000
QINIU_IMAGE_TIMEOUT_MS=90000
JIMENG_IMAGE_TIMEOUT_MS=90000
VOLCES_IMAGE_TIMEOUT_MS=90000

# ---- 3. 调整 IPM/RPM 限制 ----
# 根据实际 API 配额调整，避免不必要的限流等待
# Google (默认 10 IPM / 150 RPM)
GOOGLE_IMAGE_IPM=15
GOOGLE_IMAGE_RPM=200

# Qiniu (默认 10 IPM / 150 RPM)
QINIU_IMAGE_IPM=20
QINIU_IMAGE_RPM=300

# Jimeng (默认 10 IPM / 150 RPM)
JIMENG_IMAGE_IPM=30
JIMENG_IMAGE_RPM=500

# Volces (默认 500 IPM / 150 RPM)
VOLCES_IMAGE_IPM=500
VOLCES_IMAGE_RPM=300

# ---- 4. 多渠道配置示例 ----
# 使用 JSON 配置多个 provider，实现负载均衡
# 注意：权重应该根据实际响应速度调整
IMAGE_PROVIDERS='[
  {
    "id": "volces-fast-1",
    "type": "volces",
    "apiKey": "${VOLCES_API_KEY}",
    "baseUrl": "https://ark.cn-beijing.volces.com",
    "model": "doubao-seedream-5-0-260128",
    "maxIpm": 500,
    "maxRpm": 300,
    "weight": 8,
    "enabled": true,
    "timeoutMs": 90000
  },
  {
    "id": "jimeng-fast-1",
    "type": "jimeng",
    "apiKey": "${JIMENG_ACCESS_KEY}:${JIMENG_SECRET_KEY}",
    "model": "jimeng_seedream46_cvtob",
    "maxIpm": 30,
    "maxRpm": 500,
    "weight": 6,
    "enabled": true,
    "timeoutMs": 90000
  },
  {
    "id": "qiniu-backup-1",
    "type": "qiniu",
    "apiKey": "${QINIU_IMAGE_API_KEY}",
    "baseUrl": "https://api.qnaigc.com",
    "model": "openai/gpt-image-2",
    "maxIpm": 20,
    "maxRpm": 300,
    "weight": 3,
    "enabled": true,
    "timeoutMs": 90000
  }
]'

