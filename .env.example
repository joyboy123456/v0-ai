# --- Image API provider switch ---
# google:  use Google's official Gemini image API (default, recommended for AI 服装大片)
# raycast: use the OpenAI-compatible local proxy (fallback)
IMAGE_API_PROVIDER=google

# ============================================================
# Cloudflare 后端基础设施（05-19-cloudflare-backend-foundation）
# 真实凭证在控制台获取后写到 .env.local（不入仓库）
# ============================================================

# Cloudflare 账号 ID（Dashboard 右下角 / wrangler whoami 可见）
CLOUDFLARE_ACCOUNT_ID=
# wrangler CLI 用的 Account API Token（需要 R2 + D1 + KV + Pages 权限）
CLOUDFLARE_API_TOKEN=

# R2 对象存储（用户上传图 + AI 生成结果）
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_BUCKET=sujie
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev

# D1 数据库（任务/素材/作品元数据，替代 data/fashion-mvp-store.json）
D1_DATABASE_ID=
D1_DATABASE_NAME=yibai-fission-db

# KV 命名空间（会话/缓存）
KV_NAMESPACE_ID=

# 应用端访问 Cloudflare REST API 的专用 Token（控制台创建，需要 D1 Edit + KV Edit 权限）
CLOUDFLARE_D1_KV_TOKEN=

# 应用部署模式
# local: 沿用 data/fashion-mvp-store.json + 本地图片目录
# cloud: 走 R2 + D1 + KV 新路径
STORAGE_MODE=local
# local 模式认证策略：
# super-admin: 内网演示直接进入工作台，所有请求视为 LOCAL_SUPER_ADMIN_USERNAME
# password: 仍需 user01 / 123456 登录
LOCAL_AUTH_MODE=super-admin
LOCAL_SUPER_ADMIN_USERNAME=user01
# local 模式图片根目录。留空默认 public/generated；客户内网演示建议填仓库外目录，
# 例如 /Users/yourname/yibai-local-images，避免生成图混入代码目录。
LOCAL_IMAGE_ROOT=

# --- Google Gemini official API (main path) ---
# Get a key from https://aistudio.google.com/apikey
GOOGLE_API_KEY=
# 仅保留 3 系列；按需切换：
#   gemini-3.1-flash-image-preview  Nano Banana  推荐默认，支持 4K，~2 分钟
#   gemini-3-pro-image-preview      Nano Banana Pro 历史兼容/手动配置，thinking 模式，较慢
# AI 服装大片可在前端按任务切换；其他模块走此环境变量。
GOOGLE_IMAGE_MODEL=gemini-3.1-flash-image-preview
# 3 系列 + 2K/4K + 多图最坏情况下单图可达 5-8 分钟。默认 600s 是安全线，
# 强烈建议不要调到 480s 以下，否则 2K 以上画质 + 多图必定超时。
GOOGLE_IMAGE_TIMEOUT_MS=600000

# --- Raycast Local Proxy (OpenAI-compatible, fallback) ---
IMAGE_API_BASE_URL=http://127.0.0.1:11436/v1
IMAGE_API_KEY=
IMAGE_API_MODEL=gpt-image-2
IMAGE_API_TIMEOUT_MS=120000
IMAGE_API_SKIP_HEALTHCHECK=0

# Set to 1 to force local demo images without calling any provider.
IMAGE_API_DEMO=0

# --- Google 生图稳定性（第一阶段，仅官方 Google API） ---
# 客户端节流：每分钟最多发起的 image 请求数。Free=2 / Tier 1=10 / Tier 2=50。
GOOGLE_IMAGE_IPM=10
# 客户端节流：每分钟最多发起的请求数。Tier 1=150 / Tier 2=1000。
GOOGLE_IMAGE_RPM=150
# 重试总尝试次数（含首次）。
GOOGLE_IMAGE_RETRY_ATTEMPTS=4
# 重试基础退避（毫秒），实际延迟 = base × 2^(attempt-1) × (1 ± 0.25 jitter)。
GOOGLE_IMAGE_RETRY_BASE_DELAY_MS=1000
# 重试最大退避（毫秒），用作上面公式的封顶。
GOOGLE_IMAGE_RETRY_MAX_DELAY_MS=60000

# --- 多渠道并发生图（可选，v5 新增） ---
# JSON 数组格式。配置后系统会将多张图轮询分发到不同渠道，提高并发和稳定性。
# 不配置时自动降级到上面的 GOOGLE_API_KEY 单渠道模式。
# 支持 type: "google"（直连 Google API）和 "qiniu"（七牛云代理）。
# 七牛渠道本项目只允许 gemini-* 与 openai/gpt-image-*，不要填 Kling / Flux / SD 等模型。
# 前端选择 GPT Image 2（gpt-image-2）时，必须至少配置一个可用 qiniu provider。
# IMAGE_PROVIDERS='[
#   {
#     "id": "google-1",
#     "type": "google",
#     "apiKey": "AIzaSy...",
#     "model": "gemini-3.1-flash-image-preview",
#     "maxIpm": 10,
#     "maxRpm": 150,
#     "weight": 1,
#     "timeoutMs": 600000
#   },
#   {
#     "id": "qiniu-1",
#     "type": "qiniu",
#     "apiKey": "your-qiniu-api-key",
#     "baseUrl": "https://api.qnaigc.com",
#     "model": "gemini-3.0-pro-image-preview",
#     "maxIpm": 10,
#     "maxRpm": 150,
#     "weight": 1,
#     "timeoutMs": 600000
#   },
#   {
#     "id": "qiniu-gpt-1",
#     "type": "qiniu",
#     "apiKey": "your-qiniu-api-key",
#     "baseUrl": "https://api.qnaigc.com",
#     "model": "openai/gpt-image-2",
#     "maxIpm": 10,
#     "maxRpm": 150,
#     "weight": 1,
#     "timeoutMs": 600000
#   }
# ]'
