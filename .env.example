# --- Image API provider switch ---
# google:  use Google's official Gemini image API (default, recommended for AI 服装大片)
# raycast: use the OpenAI-compatible local proxy (fallback)
IMAGE_API_PROVIDER=google

# --- Google Gemini official API (main path) ---
# Get a key from https://aistudio.google.com/apikey
GOOGLE_API_KEY=
# 仅保留 3 系列；按需切换：
#   gemini-3.1-flash-image-preview  Nano Banana 2  推荐默认，支持 4K，~2 分钟
#   gemini-3-pro-image-preview      Nano Banana Pro 旗舰画质，thinking 模式，较慢
# AI 服装大片可在前端按任务切换；其他模块走此环境变量。
GOOGLE_IMAGE_MODEL=gemini-3.1-flash-image-preview
# 3 系列 + 2K/4K + 多图最坏情况下单图可达 5-8 分钟。默认 600s 是安全线，
# 强烈建议不要调到 480s 以下，否则 2K 以上画质 + 多图必定超时。
GOOGLE_IMAGE_TIMEOUT_MS=600000

# --- Raycast Local Proxy (OpenAI-compatible, fallback) ---
IMAGE_API_BASE_URL=http://127.0.0.1:11436/v1
IMAGE_API_KEY=
IMAGE_API_MODEL=gpt-image-2
IMAGE_API_TIMEOUT_MS=120000
IMAGE_API_SKIP_HEALTHCHECK=0

# Set to 1 to force local demo images without calling any provider.
IMAGE_API_DEMO=0

# --- Google 生图稳定性（第一阶段，仅官方 Google API） ---
# 客户端节流：每分钟最多发起的 image 请求数。Free=2 / Tier 1=10 / Tier 2=50。
GOOGLE_IMAGE_IPM=10
# 客户端节流：每分钟最多发起的请求数。Tier 1=150 / Tier 2=1000。
GOOGLE_IMAGE_RPM=150
# 重试总尝试次数（含首次）。
GOOGLE_IMAGE_RETRY_ATTEMPTS=4
# 重试基础退避（毫秒），实际延迟 = base × 2^(attempt-1) × (1 ± 0.25 jitter)。
GOOGLE_IMAGE_RETRY_BASE_DELAY_MS=1000
# 重试最大退避（毫秒），用作上面公式的封顶。
GOOGLE_IMAGE_RETRY_MAX_DELAY_MS=60000
